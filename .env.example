# Database — PostgreSQL connection string
# Neon:    postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Local:   postgresql://postgres:password@localhost:5432/yuwei
DATABASE_URL="postgresql://user:password@localhost:5432/yuwei"

# JWT secret — use a long random string in production
# Generate: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret"

# App
NEXT_PUBLIC_APP_NAME="悦味 Baking Studio"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# SMTP — Email verification
# Gmail example (use App Password, not account password):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587  SMTP_SECURE=false
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false  SMTP_USER=apikey
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
